<!-- 右下角上傳背景按鈕 -->
<button class="bg-upload-btn" onclick="document.getElementById('bgInput').click()">
  上傳背景照片
</button>

<script>
  function loadPhoto(event, imgId, hintId) {
    var file = event.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
      var img = document.getElementById(imgId);
      img.src = e.target.result;
      img.style.display = 'block';
      document.getElementById(hintId).style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  function loadBg(event) {
    var file = event.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
      var bg = document.getElementById('bgPhoto');
      bg.src = e.target.result;
      bg.style.display = 'block';
      document.getElementById('bgPlaceholder').style.display = 'none';
    };
    reader.readAsDataURL(file);
  }

  function submitRsvp() {
    var name = document.getElementById('rsvpName').value.trim();
    var attend = document.getElementById('rsvpAttend').value;
    var err = document.getElementById('errMsg');
    if (!name || !attend) {
      err.style.display = 'block';
      return;
    }
    err.style.display = 'none';
    document.getElementById('rsvpForm').style.display = 'none';
    document.getElementById('successBox').style.display = 'block';
  }
</script>
